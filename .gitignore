.obsidian/workspace*
.obsidian/cache
.obsidian/app.json.bak
.obsidian/hotkeys.json.bak
# file-overwrite-guard backups (*.md.bak.<ts>): redundant (git IS the history), they pollute
# every grep, AND they can preserve secrets (2026-06-05 credential incident). Never commit; swept periodically.
*.bak.*
# Python bytecode from running the vault skills (generate.py / reconcile.py / lint.py)
__pycache__/
*.pyc
.trash/
*.tmp
~$*
.DS_Store
Thumbs.db
# Obsidian-UI artifacts (Ahmad never opens Obsidian; any Untitled.* or
# root-level YYYY-MM-DD.md is auto-created junk, not legitimate content)
/Untitled.canvas
/Untitled*.base
/Untitled.md
/*.canvas
# Obsidian graph-view UI state — churns scale/zoom every session; owner never opens Obsidian (ADR-0001)
.obsidian/graph.json
# stray root index-generator misfire (the real synthesis index is index/synthesis.md)
/index-synthesis.md

# --- secret-safety hardening 2026-06-06 (ref: 2026-06-05 credential incident) ---
.env
.env.*
*.key
*.pem
*.pfx
credentials.json
client_secret*.json
# combined-export blob (regenerated for NotebookLM; git is the real history, don't version the blob)
/_export/
